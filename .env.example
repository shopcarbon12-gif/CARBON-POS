# Carbon POS — environment variables
# Copy this file to .env.local for development.
# In production, set these in the Coolify UI for the pos.shopcarbon.com app.

# Same Postgres instance as CarbonWMS. Both apps share this database.
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Local dev runs on http://localhost:5000 (set in package.json scripts).
NEXTAUTH_URL=http://localhost:5000

# Stripe Terminal — use sk_test_... in development, sk_live_... in production
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email receipts (Resend)
RESEND_API_KEY=
RECEIPT_FROM_EMAIL=receipts@shopcarbon.com

# Network thermal printer (ESC/POS). Leave blank in dev to skip printing.
THERMAL_PRINTER_HOST=
THERMAL_PRINTER_PORT=9100

# Default cash drawer kick command — most printers ESC p 0 25 250
CASH_DRAWER_KICK=1

# Set to 1 to use the simulated Stripe Terminal reader in development.
NEXT_PUBLIC_STRIPE_TERMINAL_SIMULATED=1
